generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  role             Role              @default(QA)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  assignedBugs     Bug[]             @relation("BugAssignee")
  createdBugs      Bug[]             @relation("BugReporter")
  createdRules     BusinessRule[]    @relation("RuleCreator")
  developerProfile DeveloperProfile?
  createdProjects  Project[]         @relation("ProjectCreator")
  qaProfile        QAProfile?
  refreshTokens    RefreshToken[]
  createdTestCases TestCase[]        @relation("TestCaseCreator")

  @@map("users")
}

model QAProfile {
  id              String          @id @default(uuid())
  userId          String          @unique
  name            String
  experienceLevel ExperienceLevel @default(JUNIOR)
  specializations String[]        @default([])
  bio             String?
  avatarUrl       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("qa_profiles")
}

model DeveloperProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  techStack String[] @default([])
  team      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("developer_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Project {
  id            String         @id @default(uuid())
  name          String
  objective     String
  actors        String[]
  description   String?
  isArchived    Boolean        @default(false)
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bugs          Bug[]
  businessRules BusinessRule[]
  createdBy     User           @relation("ProjectCreator", fields: [createdById], references: [id])
  testCases     TestCase[]

  @@map("projects")
}

model BusinessRule {
  id          String     @id @default(uuid())
  ruleCode    String
  description String
  projectId   String
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   User       @relation("RuleCreator", fields: [createdById], references: [id])
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases   TestCase[]

  @@unique([projectId, ruleCode])
  @@map("business_rules")
}

model TestCase {
  id             String        @id @default(uuid())
  testCode       String
  title          String
  description    String?
  steps          String[]      @default([])
  expectedResult String
  actualResult   String?
  output         TestOutput
  riskLevel      RiskLevel     @default(MEDIUM)
  projectId      String
  businessRuleId String?
  createdById    String
  cypressSpecRef String?
  isAiGenerated  Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  cypressRuns    CypressRun[]
  businessRule   BusinessRule? @relation(fields: [businessRuleId], references: [id])
  createdBy      User          @relation("TestCaseCreator", fields: [createdById], references: [id])
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, testCode])
  @@map("test_cases")
}

model Bug {
  id             String       @id @default(uuid())
  bugCode        String
  title          String
  description    String
  severity       Severity
  priority       Priority
  status         BugStatus    @default(OPEN)
  stepsToRepro   String[]
  expectedResult String
  actualResult   String
  environment    String?
  projectId      String
  reportedById   String
  assignedToId   String?
  isAiGenerated  Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  attachments    Attachment[]
  comments       BugComment[]
  assignedTo     User?        @relation("BugAssignee", fields: [assignedToId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportedBy     User         @relation("BugReporter", fields: [reportedById], references: [id])

  @@unique([projectId, bugCode])
  @@map("bugs")
}

model BugComment {
  id        String   @id @default(uuid())
  bugId     String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bug       Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)

  @@map("bug_comments")
}

model Attachment {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  fileType     FileType
  size         Int
  url          String
  bugId        String
  uploadedAt   DateTime @default(now())
  bug          Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model CypressRun {
  id          String        @id @default(uuid())
  testCaseId  String
  status      CypressStatus @default(PENDING)
  specFile    String?
  logs        String?
  duration    Int?
  screenshots String[]      @default([])
  triggeredAt DateTime      @default(now())
  completedAt DateTime?
  testCase    TestCase      @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@map("cypress_runs")
}

model AiGenerationLog {
  id         String   @id @default(uuid())
  type       String
  prompt     String
  response   String
  model      String
  tokensUsed Int?
  projectId  String?
  createdAt  DateTime @default(now())

  @@map("ai_generation_logs")
}

enum Role {
  QA
  DEVELOPER
  ADMIN
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum TestOutput {
  VALID
  INVALID
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum FileType {
  IMAGE
  VIDEO
  PDF
  OTHER
}

enum CypressStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  ERROR
}
